# Copy to .env.local — never commit secrets.

# Production: canonical URL for metadata / Open Graph (e.g. https://your-domain.com)
NEXT_PUBLIC_SITE_URL=

# Optional: Supabase (see src/integrations/supabase/client.ts)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional: Stripe — wire integrations/stripe/server.ts before production
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
